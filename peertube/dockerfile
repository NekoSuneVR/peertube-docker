FROM node:20-bookworm

LABEL org.opencontainers.image.title="PeerTube"
LABEL org.opencontainers.image.version="6.3.3"

ARG PEERTUBE_VERSION=v6.3.3

# Build needs dev dependencies
ENV NODE_ENV=development
ENV PEERTUBE_VERSION=${PEERTUBE_VERSION}

RUN apt-get update && apt-get install -y \
    git \
    ffmpeg \
    python3 \
    make \
    g++ \
    imagemagick \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone exact PeerTube tag
RUN git init \
    && git remote add origin https://github.com/Chocobozzz/PeerTube.git \
    && git fetch --depth 1 origin refs/tags/${PEERTUBE_VERSION}:refs/tags/${PEERTUBE_VERSION} \
    && git checkout ${PEERTUBE_VERSION}

# Install Yarn 1.x
RUN corepack enable \
    && corepack prepare yarn@1.22.22 --activate

# Install ALL dependencies (including TypeScript)
RUN yarn install --frozen-lockfile

# Install client dependencies
WORKDIR /app/client
RUN yarn install --frozen-lockfile

WORKDIR /app

# Build
RUN yarn build

# Remove development dependencies after build
RUN yarn install --production --ignore-scripts --prefer-offline

# Runtime environment
ENV NODE_ENV=production

RUN mkdir -p \
    /data \
    /config \
    /storage

EXPOSE 9000

VOLUME ["/data","/config","/storage"]

CMD ["node","dist/server"]
